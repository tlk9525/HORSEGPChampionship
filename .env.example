# Copy this file to .env and replace placeholder values locally.
# Never commit .env or real passwords, API keys, or connection strings.

# Application
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4000
FRONTEND_URL=http://127.0.0.1:5173/
VITE_API_URL=http://127.0.0.1:4000/api
APP_URL=http://127.0.0.1:5173

# PostgreSQL local connection
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=horse_racing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-local-database-password
POSTGRES_SSL=false

# Alternatively, hosting providers can supply one connection string.
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# Gmail SMTP
# Enable 2-Step Verification on the sender account and create an App Password.
GMAIL_USER=sender@example.com
GMAIL_APP_PASSWORD=replace-with-google-app-password

# Sessions and cookies
SESSION_DAYS=7
SESSION_COOKIE_NAME=horse-racing-session
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# Domain limits
MAX_OWNER_HORSES=10
MAX_RACE_FIELD_SIZE=10
MIN_READIED_PARTICIPANTS=5
MAX_TOURNAMENT_RACES=10
